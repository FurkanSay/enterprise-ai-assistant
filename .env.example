# =========================================================================
# Kurumsal AI Asistan Platformu — Environment Variables
# Copy this file to .env and fill in the values.
# =========================================================================

# ─── LLM Providers ────────────────────────────────────────────────────────
# OpenRouter is the primary path — one key, every model. LiteLLM picks the
# right downstream provider from the `openrouter/...` model prefix. The
# native Anthropic / OpenAI keys are only filled in if you want LiteLLM
# to bypass OpenRouter for that specific provider.
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
COHERE_API_KEY=
VOYAGE_API_KEY=

# Optional: local LLM via Ollama (point to host machine in dev)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ─── Postgres ─────────────────────────────────────────────────────────────
POSTGRES_USER=kai
POSTGRES_PASSWORD=kai_dev_pwd
POSTGRES_DB=kai

# ─── MinIO (S3-compatible) ────────────────────────────────────────────────
MINIO_ROOT_USER=kai_admin
MINIO_ROOT_PASSWORD=kai_minio_pwd
MINIO_BUCKET_DOCUMENTS=documents
MINIO_BUCKET_GENERATED=generated

# ─── Identity / JWT ───────────────────────────────────────────────────────
# RS256 keys: generate with: openssl genrsa -out jwt-private.pem 2048
JWT_ISSUER=kurumsal-ai-asistan
JWT_AUDIENCE=kai-platform
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=2592000

# ─── Observability ────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAMESPACE=kai
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ─── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=info             # debug | info | warn | error
RUST_LOG=info,tower_http=debug

# ─── Environment ──────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
SPRING_PROFILES_ACTIVE=docker
NODE_ENV=development

# ─── AI Engine specifics ──────────────────────────────────────────────────
DEFAULT_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
DEFAULT_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# Default model — uses OpenRouter's namespace. Swap to any model from
# https://openrouter.ai/models without touching code. Examples:
#   openrouter/anthropic/claude-3.5-sonnet
#   openrouter/openai/gpt-4o
#   openrouter/meta-llama/llama-3.3-70b-instruct
#   openrouter/meta-llama/llama-3.2-3b-instruct:free   ← zero-cost demo
DEFAULT_LLM_MODEL=openrouter/anthropic/claude-3.5-sonnet
MAX_TOOL_ITERATIONS_FREE=10
MAX_TOOL_ITERATIONS_PRO=50
MAX_TOKENS_PER_REQUEST=8192

# ─── Tenant defaults ──────────────────────────────────────────────────────
DEFAULT_TENANT_QUOTA_DOCS=100
DEFAULT_TENANT_QUOTA_TOKENS_MONTHLY=1000000
