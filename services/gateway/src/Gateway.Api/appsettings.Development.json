{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "Jwt": {
    "Authority": "http://localhost:8081"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  },
  "ReverseProxy": {
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-1": { "Address": "http://localhost:8081" }
        }
      },
      "documents-cluster": {
        "Destinations": {
          "documents-1": { "Address": "http://localhost:8082" }
        }
      },
      "aiengine-cluster": {
        "Destinations": {
          "aiengine-1": { "Address": "http://localhost:8084" }
        }
      }
    }
  }
}
