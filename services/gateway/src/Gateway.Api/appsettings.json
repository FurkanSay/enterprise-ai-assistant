{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "Jwt": {
    "Authority": "http://identity:8081",
    "Issuer": "kurumsal-ai-asistan",
    "Audience": "kai-platform"
  },
  "RateLimit": {
    "PerTenantPerMinute": 120
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:8080"
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "identity": {
        "ClusterId": "identity-cluster",
        "Match": { "Path": "/api/v1/auth/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/v1/{**catch-all}" }
        ]
      },
      "identity-protected": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/api/v1/users/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/v1/users/{**catch-all}" }
        ]
      },
      "documents": {
        "ClusterId": "documents-cluster",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/api/v1/documents/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/v1/documents/{**catch-all}" }
        ]
      },
      "aiengine-chat": {
        "ClusterId": "aiengine-cluster",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/api/v1/chat" },
        "Transforms": [
          { "PathPattern": "/v1/chat" }
        ]
      },
      "aiengine-sessions": {
        "ClusterId": "aiengine-cluster",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/api/v1/sessions/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/v1/sessions/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-1": { "Address": "http://identity:8081" }
        }
      },
      "documents-cluster": {
        "Destinations": {
          "documents-1": { "Address": "http://documents:8082" }
        }
      },
      "aiengine-cluster": {
        "Destinations": {
          "aiengine-1": { "Address": "http://aiengine:8084" }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
